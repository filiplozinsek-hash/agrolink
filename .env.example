# Copy this file to server/.env and fill in the values

# Server
PORT=3001
NODE_ENV=production

# Security — generate a random 64-char string for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Client (set this on Railway as a build-time env var, not a runtime one)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Persistent storage paths — set these when using a Railway volume
# DB_PATH=/data/agrolink.db
# UPLOADS_DIR=/data/uploads
