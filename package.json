{
  "name": "agrolink",
  "version": "1.0.0",
  "description": "Farm-to-consumer marketplace",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix server install --omit=dev && npm --prefix client install && npm --prefix client run build",
    "start": "node --no-warnings server/index.js",
    "reseed": "node --no-warnings server/db/seed.js --force",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0"
  }
}
